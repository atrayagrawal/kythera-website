{
  "name": "kythera-website",
  "version": "1.0.0",
  "description": "Kythera Music Wellness Community Website",
  "scripts": {
    "build": "npm run build:css && eleventy",
    "build:css": "tailwindcss -i src/assets/css/input.css -o src/assets/css/styles.css --minify",
    "serve": "npm run build:css && eleventy --serve",
    "watch:css": "tailwindcss -i src/assets/css/input.css -o src/assets/css/styles.css --watch",
    "debug": "DEBUG=* eleventy",
    "fetch-sheets": "node scripts/fetch-sheets.js"
  },
  "keywords": [
    "kythera",
    "music",
    "wellness",
    "community"
  ],
  "author": "Kythera",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-navigation": "^0.3.5",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.3.1",
    "googleapis": "^128.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  }
}
