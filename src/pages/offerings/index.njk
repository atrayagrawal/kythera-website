---
layout: layouts/base.njk
title: Offerings
permalink: /offerings/
---

<section class="bg-black py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-violet-light text-xs font-medium uppercase tracking-label mb-4">What We Offer</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Ways to Practice With Us</h1>
      <p class="text-lg text-white/70">From weekly community jams to corporate programs, find your way into the circle.</p>
    </div>
  </div>
</section>

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-6">
      {% for offering in offerings %}
        {% if offering.status != 'inactive' %}
          <div class="{% if offering.status == 'coming_soon' %}border-2 border-dashed border-gray-200{% else %}border border-gray-100{% endif %} rounded-2xl p-8 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-violet-primary rounded-full flex items-center justify-center mb-6 text-2xl">
              {{ offering.icon }}
            </div>
            <h2 class="text-2xl font-semibold text-black mb-2">
              {{ offering.name }}
              {% if offering.status == 'coming_soon' %}
                <span class="ml-2 text-xs font-medium text-gray-400 uppercase tracking-label">Coming Soon</span>
              {% endif %}
            </h2>
            <p class="text-gray-600 mb-6">{{ offering.tagline }}</p>
            {% if offering.status == 'active' %}
              <a href="{{ '/offerings/' + offering.id + '/' | url }}" class="inline-flex items-center text-violet-primary font-medium hover:text-violet-dark">
                Learn More
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
