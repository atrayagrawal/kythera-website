---
layout: layouts/base.njk
title: Gallery
permalink: /gallery/
---

<section class="bg-black py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-violet-light text-xs font-medium uppercase tracking-label mb-4">Visual Stories</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Gallery</h1>
      <p class="text-lg text-white/70">Moments from the circle.</p>
    </div>
  </div>
</section>

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Photo Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {% for photo in gallery %}
        {% if photo.status == 'show' %}
          <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden">
            <img src="{{ photo.url }}" alt="{{ photo.caption }}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy">
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Instagram CTA -->
    <div class="mt-16 text-center">
      <p class="text-gray-600 mb-4">See more moments on Instagram</p>
      <a href="https://instagram.com/kythera" target="_blank" rel="noopener" class="inline-flex items-center text-violet-primary font-medium hover:text-violet-dark">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
