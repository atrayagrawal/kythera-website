<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://kythera.city/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://kythera.city/offerings/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  {% for offering in offerings %}
  {% if offering.status == 'active' %}
  <url>
    <loc>https://kythera.city/offerings/{{ offering.id }}/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endif %}
  {% endfor %}
  <url>
    <loc>https://kythera.city/about/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://kythera.city/community/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://kythera.city/connect/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://kythera.city/gallery/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
</urlset>
