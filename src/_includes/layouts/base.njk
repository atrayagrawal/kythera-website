<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Kythera - Music Wellness Community</title>
  <meta name="description" content="{{ description | default('Kythera is a music wellness community in Jaipur, India. Join us for weekly jams, bhakti sessions, and transformative sound experiences.') }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}Kythera">
  <meta property="og:description" content="{{ description | default('A music wellness community in Jaipur, India') }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://kythera.city{{ page.url }}">
  <meta property="og:image" content="https://kythera.city/assets/images/og-image.jpg">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="{{ '/assets/images/favicon.svg' | url }}">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
</head>
<body class="min-h-screen flex flex-col">
  {% include "components/header.njk" %}

  <main class="flex-grow">
    {{ content }}
  </main>

  {% include "components/footer.njk" %}

  <!-- Scripts -->
  <script src="{{ '/assets/js/main.js' | url }}"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
