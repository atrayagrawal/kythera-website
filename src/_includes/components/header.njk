<header class="fixed top-0 left-0 right-0 z-50 bg-black/95 backdrop-blur-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="{{ '/' | url }}" class="text-white font-bold text-xl tracking-label uppercase">
        Kythera
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {% for item in navigation.main %}
          {% if item.children %}
            <div class="relative group">
              <button class="text-white/80 hover:text-white text-sm font-medium tracking-nav transition-colors flex items-center">
                {{ item.title }}
                <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="absolute left-0 mt-2 w-56 bg-white rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left">
                <div class="py-2">
                  {% for child in item.children %}
                    <a href="{{ child.url | url }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-violet-primary hover:text-white transition-colors">
                      {{ child.title }}
                    </a>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% else %}
            <a href="{{ item.url | url }}" class="text-white/80 hover:text-white text-sm font-medium tracking-nav transition-colors">
              {{ item.title }}
            </a>
          {% endif %}
        {% endfor %}

        <!-- CTA Button -->
        <a href="{{ navigation.cta.url | url }}" class="btn-primary text-sm">
          {{ navigation.cta.title }}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden text-white p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-black z-50 hidden">
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between p-4 border-b border-white/10">
        <span class="text-white font-bold text-xl tracking-label uppercase">Kythera</span>
        <button id="mobile-menu-close" class="text-white p-2" aria-label="Close menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="flex-1 overflow-auto py-8 px-6">
        <div class="space-y-6">
          {% for item in navigation.main %}
            {% if item.children %}
              <div>
                <h3 class="text-white/60 text-sm font-medium uppercase tracking-label mb-3">{{ item.title }}</h3>
                <div class="space-y-2 ml-2">
                  {% for child in item.children %}
                    <a href="{{ child.url | url }}" class="block text-white text-lg hover:text-violet-light transition-colors">
                      {{ child.title }}
                    </a>
                  {% endfor %}
                </div>
              </div>
            {% else %}
              <a href="{{ item.url | url }}" class="block text-white text-xl font-medium hover:text-violet-light transition-colors">
                {{ item.title }}
              </a>
            {% endif %}
          {% endfor %}
        </div>
        <div class="mt-8 pt-8 border-t border-white/10">
          <a href="{{ navigation.cta.url | url }}" class="btn-primary w-full justify-center">
            {{ navigation.cta.title }}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>
