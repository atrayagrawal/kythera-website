<section class="py-16 md:py-20 bg-gray-50 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="section-eyebrow">Who It's For</p>
      <h2 class="text-2xl md:text-3xl font-bold text-black mb-6">Open to Everyone</h2>
      <p class="text-gray-600 text-lg leading-relaxed mb-8">
        You don't need to be a musician. You don't need any experience. You just need to be open to trying something new.
      </p>
      <div class="grid sm:grid-cols-3 gap-6">
        {% if offering.who_for %}
          {% for item in offering.who_for %}
            <div class="text-center">
              <div class="w-12 h-12 bg-violet-primary rounded-full flex items-center justify-center mx-auto mb-3 text-white text-xl font-bold">✓</div>
              <p class="text-gray-700 font-medium">{{ item }}</p>
            </div>
          {% endfor %}
        {% else %}
          <div class="text-center">
            <div class="w-12 h-12 bg-violet-primary rounded-full flex items-center justify-center mx-auto mb-3 text-white text-xl font-bold">✓</div>
            <p class="text-gray-700 font-medium">Absolute beginners</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-violet-primary rounded-full flex items-center justify-center mx-auto mb-3 text-white text-xl font-bold">✓</div>
            <p class="text-gray-700 font-medium">Experienced musicians</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-violet-primary rounded-full flex items-center justify-center mx-auto mb-3 text-white text-xl font-bold">✓</div>
            <p class="text-gray-700 font-medium">The curious</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
