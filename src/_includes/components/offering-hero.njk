<section class="bg-black py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <!-- Back link -->
      <a href="/offerings/" class="inline-flex items-center text-white/60 hover:text-white text-sm mb-8 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Offerings
      </a>

      <!-- Icon -->
      <div class="w-16 h-16 bg-violet-primary rounded-full flex items-center justify-center mb-6 text-3xl">
        {{ offering.icon }}
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">{{ offering.name }}</h1>
      <p class="text-xl text-white/70 mb-8">{{ offering.tagline }}</p>

      <!-- Key details -->
      <div class="flex flex-wrap gap-6 text-white/60 text-sm">
        {% if offering.schedule %}
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {{ offering.schedule }}
          </span>
        {% endif %}
        {% if offering.location %}
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
            {{ offering.location }}
          </span>
        {% endif %}
        {% if offering.price %}
          <span class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {{ offering.price }}
          </span>
        {% endif %}
      </div>
    </div>
  </div>
</section>
